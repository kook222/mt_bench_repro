# ============================================================
# Korean MT-Bench .gitignore
# ============================================================

# ── Python 빌드/캐시 ─────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/

# ── Jupyter ──────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── 모델 가중치 (수십 GB → 절대 커밋 금지) ──────────────────
*.bin
*.safetensors
*.pt
*.pth
*.ckpt
models/

# ── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
.claude/

# ── 환경변수 / API 키 (절대 커밋 금지) ──────────────────────
.env
.env.*
secrets.yaml

# ── 원본 영어 질문 파일 (FastChat에서 별도 다운로드) ─────────
# 다운로드: scripts/tools/download_dataset.sh
data/en/questions.jsonl

# ── 한국어 질문 파일 (수작업 번역 — git에서 별도 관리) ───────
# 번역 완성 후 명시적으로 git add data/ko/questions.jsonl
data/ko/questions_back.jsonl

# ── 로그 ─────────────────────────────────────────────────────
*.log
vllm_server.log
run.out

# ── 테스트 임시 디렉토리 ─────────────────────────────────────
/tmp/
data/mock/
scripts/**/__pycache__/
src/**/__pycache__/

# ── 영어 실험 raw 산출물 (A100 생성, 재생성 가능) ────────────
data/en/answers_unseen/
data/en/archive/
data/en/judgments/
data/en/judgments_unseen/

# ── 한국어 실험 raw 산출물 (A100 생성, 재생성 가능) ──────────
data/ko/answers/
data/ko/judgments/

# ============================================================
# git으로 관리하는 산출물 (추적 목적)
# ============================================================
# data/en/answers/*.jsonl      → 영어 eval 답변 (baseline)
# data/en/results/*.csv        → 영어 집계 결과
# data/ko/results/*.csv        → 한국어 집계 결과 (Phase 1 이후)
# figures/en/*.png             → 영어 실험 figure
# figures/ko/*.png             → 한국어 실험 figure
# ============================================================

# 다운로드 스크립트는 항상 포함
!scripts/tools/download_dataset.sh
*.jsonl.bak
