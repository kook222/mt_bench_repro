# ============================================================
# MT-Bench 재현 프로젝트 .gitignore
# ============================================================

# ── Python 빌드/캐시 ─────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/

# ── Jupyter ──────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── 모델 가중치 (수십 GB → 절대 커밋 금지) ──────────────────
*.bin
*.safetensors
*.pt
*.pth
*.ckpt
models/

# ── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
.claude/

# ── 환경변수 / API 키 (절대 커밋 금지) ──────────────────────
.env
.env.*
secrets.yaml

# ── 전체 80문항 질문 파일 (FastChat에서 별도 다운로드) ───────
# 다운로드 방법: scripts/tools/download_dataset.sh 참고
data/mt_bench_questions.jsonl

# ── 로그 ─────────────────────────────────────────────────────
*.log
vllm_server.log
run.out

# ── 테스트 임시 디렉토리 ─────────────────────────────────────
/tmp/
data/mock/
paper/*.aux
paper/*.log
paper/*.out
scripts/**/__pycache__/
src/**/__pycache__/

# ── 재생성 가능한 raw 산출물 ─────────────────────────────────
data/answers_unseen/
data/archive/
data/judgments_phase1/
data/judgments_phase2/
data/judgments_phase3/
data/judgments_phase4/
data/judgments_phase5/
data/judgments_unseen/

# ============================================================
# 아래 요약 산출물만 git으로 관리 (실험 결과 추적 목적)
# ============================================================
# data/results*.csv → 집계 결과 (점수표, 랭킹)
# figures/*.png     → 논문/README용 최종 figure
# paper/*.pdf       → 제출용 산출물
# ============================================================

# 샘플 파일과 다운로드 스크립트는 항상 포함
!data/mt_bench_questions_sample.jsonl
!scripts/tools/download_dataset.sh
