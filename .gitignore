# ============================================================
# MT-Bench 재현 프로젝트 .gitignore
# ============================================================

# ── Python 빌드/캐시 ─────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/

# ── Jupyter ──────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── 모델 가중치 (수십 GB → 절대 커밋 금지) ──────────────────
*.bin
*.safetensors
*.pt
*.pth
*.ckpt
models/

# ── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ── 환경변수 / API 키 (절대 커밋 금지) ──────────────────────
.env
.env.*
secrets.yaml

# ── 전체 80문항 질문 파일 (FastChat에서 별도 다운로드) ───────
# 다운로드 방법: scripts/download_dataset.sh 참고
data/mt_bench_questions.jsonl

# ── 로그 ─────────────────────────────────────────────────────
*.log
vllm_server.log
run.out

# ── 테스트 임시 디렉토리 ─────────────────────────────────────
/tmp/
data/mock/
paper/*.aux
paper/*.log
paper/*.out

# ============================================================
# 아래 데이터 파일은 git으로 관리 (실험 결과 추적 목적)
# ============================================================
# data/answers/     → 각 모델의 답변 JSONL (모델명.jsonl)
# data/judgments/   → judge 채점 결과 JSONL
# data/results*.csv → 집계 결과 (점수표, 랭킹)
# ============================================================

# 샘플 파일과 다운로드 스크립트는 항상 포함
!data/mt_bench_questions_sample.jsonl
!scripts/download_dataset.sh
