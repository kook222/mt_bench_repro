# ============================================================
# Korean MT-Bench .gitignore
# ============================================================

# ── Python 빌드/캐시 ─────────────────────────────────────────
__pycache__/
*.py[cod]
*.so
*.egg-info/
dist/
build/
.venv/
venv/
env/

# ── 모델 가중치 (수십 GB — 절대 커밋 금지) ───────────────────
*.bin
*.safetensors
*.pt
*.pth
*.ckpt
models/

# ── IDE / 시스템 ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
.claude/
pyrightconfig.json

# ── 환경변수 / API 키 (절대 커밋 금지) ───────────────────────
.env
.env.*
secrets.yaml

# ── 개인 서버/계정 실행 가이드 (공개 저장소 제외) ─────────────
A100_실행가이드.md
*_실행가이드.md

# ── 로그 ─────────────────────────────────────────────────────
*.log
*.out
vllm_server.log

# ── 원본 영어 질문 파일 (download_dataset.sh로 재다운로드) ────
data/en/questions.jsonl

# ── 역번역 결과 (back_translate.py 출력) ─────────────────────
data/ko/questions_back.jsonl

# ── A100 실험 raw 산출물 ────────────────────────────────────
#   data/*/judgments/ raw JSONL은 논문 재현성 검증을 위해 git 추적
#   KO 답변은 저장소 크기 관리를 위해 제외
data/ko/answers/

# ── Mock 테스트 임시 결과 (run_mock_full.sh 출력) ─────────────
data/mock/

# ── 임시 Figure ──────────────────────────────────────────────
#   paper/figures/는 논문용 산출물로 git 추적, 아래 임시 산출물은 제외
figures/en/*.png
figures/ko/

# ── 백업 파일 ─────────────────────────────────────────────────
*.jsonl.bak
*.bak

# ============================================================
# git 추적 대상 정리
# ============================================================
#   data/en/answers/          ← 6개 eval 모델 답변 (baseline)
#   data/en/judgments/**/*.jsonl ← raw judge outputs
#   data/en/results/*.csv     ← Qwen/GPT judge 집계 결과
#   data/ko/judgments/**/*.jsonl ← raw judge outputs
#   data/ko/results/*.csv     ← 한국어 judge 집계 결과 (Phase 1 이후)
#   data/ko/questions.jsonl   ← 수작업 한국어 번역
#   paper/figures/            ← KIPS 논문용 figure PNG/PDF
#   paper/tables/             ← KIPS 논문용 copy tables
#   src/, scripts/            ← 핵심 패키지 및 스크립트
# ============================================================
